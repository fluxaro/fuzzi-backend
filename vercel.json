{
  "version": 2,
  "builds": [
    {
      "src": "fuzzi_backend/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "staticfiles/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "fuzzi_backend/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "fuzzi_backend.settings"
  },
  "buildCommand": "bash build_files.sh",
  "outputDirectory": "staticfiles"
}
