# ============================================================
# Fuzzi Backend — Environment Variables
# Copy this to .env for local dev, set these in Vercel dashboard for production
# ============================================================

# Django
DJANGO_SECRET_KEY=your-long-random-secret-key-here
DEBUG=False
ALLOWED_HOSTS=your-vercel-app.vercel.app,localhost

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://your-frontend.vercel.app,http://localhost:3000

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database — use the Supabase connection pooler URL (recommended)
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.your-ref:YOUR_DB_PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres

# OR use individual vars instead of DATABASE_URL:
# DB_HOST=aws-0-region.pooler.supabase.com
# DB_PORT=6543
# DB_NAME=postgres
# DB_USER=postgres.your-ref
# DB_PASSWORD=your-db-password
